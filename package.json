{
  "name": "inbox-rs",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/web",
    "build": "npm run build --workspace=packages/rs-module && npm run build --workspace=packages/web",
    "build:extension": "npm run build --workspace=packages/extension"
  }
}
